POSTGRES_DB=pan
POSTGRES_USER=pan
POSTGRES_PASSWORD=pan_local_password
SECRET_KEY=replace-with-a-long-random-secret-in-production
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
DEFAULT_QUOTA_BYTES=10737418240
MAX_FILE_SIZE_BYTES=1073741824
ADMIN_USERNAME=administrator
ADMIN_INITIAL_PASSWORD=123456

# Docker 基础镜像。默认使用国内镜像；网络环境需要时可替换为可访问的内部/国内镜像。
PYTHON_IMAGE=m.daocloud.io/docker.io/library/python:3.12.11-slim-bookworm
NODE_IMAGE=m.daocloud.io/docker.io/library/node:22.17.0-alpine3.21
NGINX_IMAGE=m.daocloud.io/docker.io/library/nginx:1.28.0-alpine3.21
